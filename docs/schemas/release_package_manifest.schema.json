{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://occam.world/schemas/duellum/release_package_manifest.schema.json",
  "title": "Duellum Veritatis release package manifest",
  "type": "object",
  "required": [
    "duel_id",
    "generated_at",
    "package_status",
    "files"
  ],
  "properties": {
    "duel_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "package_status": {
      "enum": [
        "draft",
        "checked",
        "published",
        "quarantined",
        "superseded"
      ]
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "public"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "public": {
            "type": "boolean"
          },
          "role": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
